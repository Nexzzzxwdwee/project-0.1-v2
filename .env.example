# Supabase — required for auth and cloud storage (optional in Phase 1, localStorage fallback)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Set to "true" to use Supabase storage instead of localStorage
NEXT_PUBLIC_USE_SUPABASE_STORAGE=false
